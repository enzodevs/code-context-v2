# Database
DATABASE_URL=postgresql://coderag:your_password@localhost:54329/coderag
POSTGRES_PASSWORD=your_password

# Voyage AI (required - get your key at https://dash.voyageai.com/)
VOYAGE_API_KEY=pa-...

# Server Config
LOG_LEVEL=INFO

# Retrieval tuning (optional)
RERANK_TOP_K_OUTPUT=8
RERANK_RELATIVE_FACTOR=0.75
RERANK_SCORE_FLOOR=0.40
RESULT_MAX_TOKENS=8000

# Search quality logging (optional, JSONL)
# Example: /tmp/cc2-search.jsonl
SEARCH_LOG_PATH=
